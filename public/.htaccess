<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Branded Sharing Redirect
  RewriteRule ^share/?$ https://nipunwrewluxaikyfbzg.functions.supabase.co/share-event [QSA,L,R=301]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
